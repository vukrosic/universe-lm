# Remote training box config for scripts/remote.sh
# Copy to `.remote` (gitignored) and edit for your current Vast instance:
#   cp .remote.example .remote
# Vast instances are ephemeral — when you rent a new box, edit HOST/PORT here
# and every `remote.sh` subcommand follows. Nothing else hardcodes them.

REMOTE_HOST=root@82.193.103.124   # user@ip of the Vast box
REMOTE_PORT=40095                 # ssh port Vast assigned
REMOTE_DIR=/root/my-life/llm-research-kit-scaling  # checkout path on the box
REMOTE_VENV=/venv/main            # PyTorch venv on the box (default Vast image)
LOCAL_FWD=8080                    # local port forwarded to remote 8080 (Streamlit/monitor)
